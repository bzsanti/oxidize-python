"""Type stubs for the oxidize-pdf native extension module."""

from typing import Optional

# ── Module metadata ────────────────────────────────────────────────────────────

__version__: str

# ── Exceptions ─────────────────────────────────────────────────────────────────

class PdfError(Exception):
    """Base exception for all oxidize-pdf errors."""
    ...

class PdfParseError(PdfError):
    """Raised when PDF parsing fails."""
    ...

class PdfIoError(PdfError):
    """Raised on I/O errors (file not found, permission denied, etc.)."""
    ...

class PdfEncryptionError(PdfError):
    """Raised on encryption/decryption errors."""
    ...

class PdfPermissionError(PdfError):
    """Raised when an operation is denied by document permissions."""
    ...

