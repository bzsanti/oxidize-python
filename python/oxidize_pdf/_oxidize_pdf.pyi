# ── Page ───────────────────────────────────────────────────────────────────────

class Page:
    """A page in a PDF document for adding text and graphics content."""

    def __init__(self, width: float, height: float) -> None: ...

    @staticmethod
    def a4() -> Page: ...
    @staticmethod
    def a4_landscape() -> Page: ...
    @staticmethod
    def letter() -> Page: ...
    @staticmethod
    def letter_landscape() -> Page: ...
    @staticmethod
    def legal() -> Page: ...
    @staticmethod
    def legal_landscape() -> Page: ...

    @property
    def width(self) -> float: ...
    @property
    def height(self) -> float: ...
    @property
    def margins(self) -> Margins: ...

    def set_margins(self, margins: Margins) -> None: ...

    # Text operations
    def set_font(self, font: Font, size: float) -> None: ...
    def set_text_color(self, color: Color) -> None: ...
    def set_character_spacing(self, spacing: float) -> None: ...
