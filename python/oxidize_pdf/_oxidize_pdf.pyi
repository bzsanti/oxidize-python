    # Graphics operations
    def set_fill_color(self, color: Color) -> None: ...
    def set_stroke_color(self, color: Color) -> None: ...
    def set_line_width(self, width: float) -> None: ...
    def set_fill_opacity(self, opacity: float) -> None: ...
    def set_stroke_opacity(self, opacity: float) -> None: ...
    def draw_rect(self, x: float, y: float, width: float, height: float) -> None: ...
    def draw_circle(self, cx: float, cy: float, radius: float) -> None: ...
    def move_to(self, x: float, y: float) -> None: ...
    def line_to(self, x: float, y: float) -> None: ...
    def curve_to(
        self, x1: float, y1: float, x2: float, y2: float, x3: float, y3: float
    ) -> None: ...
    def close_path(self) -> None: ...
    def fill(self) -> None: ...
    def stroke(self) -> None: ...
    def fill_and_stroke(self) -> None: ...

    def __repr__(self) -> str: ...

